generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings  FOPSettings?
  notifications NotificationSettings?
  incomes   Income[]
  expenses  Expense[]
  subscription Subscription?
  sessions  Session[]
  categorizationRules CategorizationRule[]
  statementImports StatementImport[]
  auditLogs AuditLog[]
  twoFactorAuth TwoFactorAuth?
  trustedDevices TrustedDevice[]
  dashboardPreference DashboardPreference?
  documentTemplates DocumentTemplate[]
  documentGenerations DocumentGeneration[]
  aiChatSessions AIChatSession[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  device    String?  // e.g. "MacBook Pro", "iPhone"
  os        String?  // e.g. "macOS", "iOS"
  browser   String?  // e.g. "Chrome"
  ip        String?
  location  String?  // e.g. "Kyiv, Ukraine"
  
  lastActive DateTime @default(now())
  isCurrent  Boolean  @default(false) // Helper for UI, though ideally determined by current token
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, lastActive])
  @@index([userId, createdAt])
}

model NotificationSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailNews      Boolean @default(true)
  monthlyReport  Boolean @default(true)
  weeklyGovReport Boolean @default(false)
  reportChannel  String  @default("email") // "email" or "sms"

  updatedAt DateTime @updatedAt
}

model FOPSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  legalName String?
  ipn       String?
  group     Int      @default(3) // fixed to 3 in app logic
  address     String?
  city        String?
  street      String?
  houseNumber String?
  zipCode     String?
  kveds     String?  // Comma separated list

  // Tax configuration (user-provided to avoid hardcoded legal assumptions)
  taxRate         Float? // e.g. 0.05 for 5%
  fixedMonthlyTax Float? // fixed monthly single tax
  esvMonthly      Float? // monthly ESV amount
  incomeLimit     Float? // annual income limit
  reportingPeriod String? // monthly | quarterly | yearly
  taxPaymentDay   Int?    // day of month for tax payment
  reportDay       Int?    // day of month for reporting

  // Document/profile data
  iban            String?
  phone           String?
  email           String?
  registrationDate DateTime?
  taxOffice       String?
  expenseCategories String? // Comma/newline separated categories for expense dictionary
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Income {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Float
  source    String
  date      DateTime
  type      String   // service, consulting, design, other
  status    String   @default("completed") // pending, completed
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date, deletedAt])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  plan      String   @default("Free") // Free, Pro
  status    String   @default("active")
  period    String   @default("monthly") // monthly, yearly
  
  startDate DateTime @default(now())
  endDate   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsage {
  id        String   @id @default(uuid())
  userId    String?  // null = guest
  date      DateTime
  count     Int      @default(0)
  
  @@unique([userId, date])
}

model Expense {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Float
  category  String
  date      DateTime
  description String?
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, date, deletedAt])
}

model CategorizationRule {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  direction   String   @default("expense") // expense | income | auto
  category    String
  containsText String?
  counterpartyContains String?
  priority    Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, direction, priority])
}

model StatementImport {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName   String
  totalRows  Int      @default(0)
  importedIncome Int  @default(0)
  importedExpense Int @default(0)
  duplicateRows Int   @default(0)
  skippedRows Int     @default(0)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  rolloutPercent Int   @default(100)
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model TwoFactorAuth {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled      Boolean  @default(false)
  secretEnc    String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model TrustedDevice {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceHash String
  fingerprintHash String?
  lastIp     String?
  userAgentHash String?
  label      String?
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, deviceHash])
  @@index([userId, lastUsedAt])
}

model DashboardPreference {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layoutJson Json?
  density    String   @default("comfortable") // compact | comfortable
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model DocumentTemplate {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  name        String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  configJson  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, type, version])
}

model DocumentGeneration {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  format            String
  number            String?
  payloadJson       Json?
  templateId        String?
  templateVersion   Int?
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

model AIChatSession {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  isPinned    Boolean         @default(false)
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lastUsedAt  DateTime        @default(now())
  messages    AIChatMessage[]

  @@index([userId, isPinned, lastUsedAt])
}

model AIChatMessage {
  id         String        @id @default(uuid())
  sessionId  String
  session    AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String
  content    String
  createdAt  DateTime      @default(now())

  @@index([sessionId, createdAt])
}
