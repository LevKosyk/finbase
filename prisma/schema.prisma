generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings  FOPSettings?
  notifications NotificationSettings?
  incomes   Income[]
  expenses  Expense[]
  subscription Subscription?
}

model NotificationSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailNews      Boolean @default(true)
  monthlyReport  Boolean @default(true)
  reportChannel  String  @default("email") // "email" or "sms"

  updatedAt DateTime @updatedAt
}

model FOPSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  legalName String?
  ipn       String?
  group     Int      @default(3) // 2 or 3
  address     String?
  city        String?
  street      String?
  houseNumber String?
  zipCode     String?
  kveds     String?  // Comma separated list
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Income {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Float
  source    String
  date      DateTime
  type      String   // service, consulting, design, other
  status    String   @default("completed") // pending, completed
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  plan      String   @default("Free") // Free, Pro
  status    String   @default("active")
  period    String   @default("monthly") // monthly, yearly
  
  startDate DateTime @default(now())
  endDate   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsage {
  id        String   @id @default(uuid())
  userId    String?  // null = guest
  date      DateTime
  count     Int      @default(0)
  
  @@unique([userId, date])
}

model Expense {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Float
  category  String
  date      DateTime
  description String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
